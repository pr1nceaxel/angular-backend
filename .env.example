# Copiez ce fichier en .env et remplissez les valeurs.

# Chaîne de connexion MongoDB Atlas (ou locale)

# Secret pour signer les JWT (chaîne longue et aléatoire en production)
JWT_SECRET=changez_moi_secret_tres_long

# Port d'écoute (Render fournit souvent PORT automatiquement)
PORT=8010

# Origines CORS autorisées, séparées par des virgules (URL du front déployé + local)
CORS_ORIGINS=http://localhost:4200
